# --- Critical: secrets and rater data must NEVER be committed ---
.env
.env.*
*.env
ratings/
archive/
logs/
*.LOCAL_BACKUP.*
*_backup.*

# --- Data: response files generally ignored, BUT canonical timepoint
# datasets are kept in the (private) repo so the cloud rating app can
# read them. Pilot/SMOKE/VERIFY runs stay archived locally.
# Note: 'data/*' (with asterisk) lets Git look inside the directory so
# the exception lines below can take effect; bare 'data/' would short-circuit.
data/*
!data/responses_T0.jsonl
!data/responses_T+3.jsonl
!data/responses_T+6.jsonl

# --- macOS noise ---
.DS_Store
.AppleDouble
.LSOverride

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Streamlit ---
.streamlit/secrets.toml

# --- Anything that looks like a key or token ---
*.pem
*.key
*api_key*
*api-key*

# --- Google Cloud service account credentials (NEVER commit) ---
gcp_service_account.json
*service_account*.json
*service-account*.json
